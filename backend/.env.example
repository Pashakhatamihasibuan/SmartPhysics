# ─── SmartPhysics Backend Environment ───

# MongoDB Connection
# Local:
MONGO_URI=mongodb://127.0.0.1:27017/smartphysics
# Atlas Cloud (ganti dengan connection string kamu):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smartphysics

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (untuk CORS)
CLIENT_URL=http://localhost:3000

# Admin Credentials (ganti sebelum deploy!)
ADMIN_USER=admin
ADMIN_PASS=smartphysics123
JWT_SECRET=smartphysics-admin-secret-2025-ganti-ini
